APP_NAME=TrendScope API
APP_ENV=development
DATABASE_URL=sqlite:///./trendscope.db
FRONTEND_ORIGIN=http://127.0.0.1:5081

SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=1800
SCHEDULER_INITIAL_DELAY_SECONDS=15
SCHEDULER_PERIOD=30d
SCHEDULER_RUN_BACKFILL_NOW=true

# Auto mode tries real providers first and falls back to mock data when
# a real request fails. Use this for incremental bring-up.
PROVIDER_MODE=auto

# GitHub
GITHUB_TOKEN=replace-with-your-token
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_HISTORY_MAX_PAGES=10

# NewsNow
NEWSNOW_BASE_URL=https://newsnow.busiyi.world
NEWSNOW_SOURCE_IDS=weibo,zhihu,bilibili,juejin,36kr,github

# Archive providers
GOOGLE_NEWS_ENABLED=true
GOOGLE_NEWS_HISTORY_DAYS=365
GOOGLE_NEWS_MAX_ITEMS=80
DIRECT_RSS_ENABLED=true
DIRECT_RSS_MAX_ITEMS=80
DIRECT_RSS_EXTRA_FEEDS=
GDELT_ENABLED=true
GDELT_HISTORY_DAYS=90
GDELT_MAX_ITEMS=80

# Optional JSON map for ambiguous keywords.
# Example: {"manus":["ai","agent","agents"],"claude":["anthropic","code","ai"]}
ARCHIVE_AMBIGUOUS_QUERY_CONTEXTS_JSON=

# Networking
REQUEST_TIMEOUT_SECONDS=8
HTTP_PROXY=
