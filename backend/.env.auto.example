APP_NAME=TrendScope API
APP_ENV=development
DATABASE_URL=sqlite:///./trendscope.db
FRONTEND_ORIGIN=http://127.0.0.1:8000

SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=1800
SCHEDULER_INITIAL_DELAY_SECONDS=15
SCHEDULER_PERIOD=30d
SCHEDULER_RUN_BACKFILL_NOW=true

# Auto mode tries real providers first and falls back to mock data when
# a real request fails. Use this for incremental bring-up.
PROVIDER_MODE=auto

# GitHub
GITHUB_TOKEN=replace-with-your-token
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_HISTORY_MAX_PAGES=10

# NewsNow
NEWSNOW_BASE_URL=https://newsnow.busiyi.world
NEWSNOW_SOURCE_IDS=weibo-hot,zhihu-hot,bilibili-hot,juejin-hot,36kr-hot,github-trending

# Networking
REQUEST_TIMEOUT_SECONDS=8
HTTP_PROXY=
